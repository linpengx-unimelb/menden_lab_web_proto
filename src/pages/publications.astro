---
import Layout from '../layouts/Layout.astro';
import { publications } from '../data/publications';

function truncateWords(text: string, maxWords: number) {
	const words = text.trim().split(/\s+/);
	if (words.length <= maxWords) {
		return text;
	}

	return `${words.slice(0, maxWords).join(' ')}...`;
}
---

<Layout
	title="Menden Lab | Publications"
	description="Latest publications associated with Michael P. Menden, synchronized from Google Scholar."
>
	<h1 class="page-title">Research Group: Publications</h1>

	<section class="stack-list publications-stack" aria-label="Publication list">
		{
			publications.map((item) => (
				<article class="content-card publication-card">
					<div class="publication-meta">
						<span>{item.year}</span>
						<span class="publication-journal">{item.journal}</span>
					</div>
					<h2 class="publication-title">{item.title}</h2>
					<p class="publication-authors" title={item.citation}>{item.citation}</p>
					{
						item.summary ? (
							<p class="publication-summary">{truncateWords(item.summary, 150)}</p>
						) : null
					}
					<div class="publication-footer">
						<a href={item.scholarUrl} target="_blank" rel="noreferrer">
							View on Google Scholar
						</a>
					</div>
				</article>
			))
		}
	</section>
</Layout>
